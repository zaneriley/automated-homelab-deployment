# Python
*.pyc
__pycache__/

# Ansible runtime
*.retry

# Legacy inventory patterns (for ansible/setup_nuc.yml; master-node inventory is tracked)
**/inventory/production
**/inventory/staging
**/inventory/*.vault
*.pem
*.key
*.tfvars
cloudflare/*.txt

# SSH private keys (belt-and-suspenders — 1Password agent serves our keys, so
# these files shouldn't exist on this machine, but if a tool ever drops them
# don't let git silently pick them up)
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
*.pub
*.pfx
*.p12
*.keystore

# Vault password file (legacy — phase-2 migrates secrets to 1Password per ADR-0007)
.vault_pass.txt
host_key_checking

# Group/host vars — tracked *.example.yml templates, gitignored real values
# (ADR-0007). Symmetric between group_vars and host_vars so new groups/hosts
# are protected by default without needing a .gitignore edit per group.
# Exception: group_vars/all.yml is tracked — it carries cross-group, non-secret
# defaults; secrets never go here (resolve via community.general.onepassword).
group_vars/*.yml
!group_vars/*.example.yml
!group_vars/all.yml
host_vars/*.yml
!host_vars/*.example.yml

# Research / scratch artifacts (literature reviews, planning docs)
.tmp/

# Per-machine agent tooling (Claude Code state, conversation transcripts, etc.)
.claude/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
*.tfplan
*.tfvars.json

# macOS / editor cruft
.DS_Store
*.swp
*~
*.bak
*.log
*.tar.gz
*.zip
.vagrant/

# Secrets / credentials (catch-all — prefer 1Password references over any local file)
.secret/
secrets.yml
*secrets*
credentials
